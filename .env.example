# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PRO_PRICE_ID=price_...
VITE_STRIPE_ULTRA_PRICE_ID=price_...

# Base44
VITE_BASE44_APP_ID=...

# Google Places API — required for Experience Guide local recommendations
# Get a key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (Legacy) or Places API (New)
# Add to Vercel: Dashboard → Settings → Environment Variables → GOOGLE_PLACES_API_KEY
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Maps JS API key — client-side (bundled into the browser build), used
# by VenueSearch.jsx / LocationPicker.jsx for the Maps + Places Autocomplete
# widget. MUST be restricted to an HTTP referrer allowlist
# (openinvite.com.au, *.vercel.app for previews) in Google Cloud Console —
# never leave a client-exposed key unrestricted.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Resend (email)
RESEND_API_KEY=re_...
