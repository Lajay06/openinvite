# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# AUD prices (existing) — $79 Pro / $149 Ultra
VITE_STRIPE_PRO_PRICE_ID=price_...
VITE_STRIPE_ULTRA_PRICE_ID=price_...

# USD prices (multi-currency pricing) — $59 Pro / $79 Ultra, one-time,
# attached to the SAME Stripe products as the AUD prices above (create via
# `stripe prices create --product <same product id> --currency usd
# --unit-amount 5900`, etc.) — never a separate product. Read by
# api/_lib/planPricing.js for tier + currency resolution. Optional: if
# unset, USD checkout sessions simply can't be created (resolvePlanFromPriceId
# returns null for a USD priceId, same as any other unrecognised price) —
# AUD-only behaviour is unaffected either way.
VITE_STRIPE_PRO_PRICE_ID_USD=price_...
VITE_STRIPE_ULTRA_PRICE_ID_USD=price_...

# Base44
VITE_BASE44_APP_ID=...

# Base44 admin API key — server-only, NEVER exposed to the browser. Used by
# api/webhooks/stripe.js (api/_lib/base44Admin.js) to write User.plan on a
# verified Stripe payment — the only path that can write the built-in User
# entity from a server context (the base44.entities.* client SDK explicitly
# cannot bulk-update User records).
BASE44_ADMIN_KEY=...

# Google Places API — required for Experience Guide local recommendations
# Get a key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (Legacy) or Places API (New)
# Add to Vercel: Dashboard → Settings → Environment Variables → GOOGLE_PLACES_API_KEY
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Maps JS API key — client-side (bundled into the browser build), used
# by VenueSearch.jsx / LocationPicker.jsx for the Maps + Places Autocomplete
# widget. MUST be restricted to an HTTP referrer allowlist
# (openinvite.com.au, *.vercel.app for previews) in Google Cloud Console —
# never leave a client-exposed key unrestricted.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Resend (email)
RESEND_API_KEY=re_...

# Pexels API — server-only, powers the "Stock photos" tab in
# MediaLibraryModal.jsx via api/stock-search.js. NEVER add a VITE_ prefix —
# it would ship in the client bundle. Free tier: 200 requests/hour.
# Get a key at https://www.pexels.com/api/ (instant, no approval wait)
# Add to Vercel: Dashboard → Settings → Environment Variables → PEXELS_API_KEY
PEXELS_API_KEY=your_pexels_api_key_here
