    "accommodation": {
      "type": "object",
      "properties": {
        "partnerRecommendationsEnabled": {
          "type": "boolean",
          "default": true
        },
        "coupleNote": {
          "type": "string"
        },
        "checkInDate": {
          "type": "string",
          "format": "date"
        },
        "checkOutDate": {
          "type": "string",
          "format": "date"
        },
        "suggestedAreas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manualProperties": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "hiddenProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pinnedProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "music": {
      "type": "object",
      "properties": {
        "spotifyConnected": {
          "type": "boolean",
          "default": false
        },
        "spotifyUserId": {
          "type": "string"
        },
        "guestRequestsEnabled": {
          "type": "boolean",
          "default": true
        },
        "requestsRequireApproval": {
          "type": "boolean",
          "default": true
        },
        "requestsClosedDate": {
          "type": "string",
          "format": "date"
        },
        "limitOnePerGuest": {
          "type": "boolean",
          "default": false
        },
        "onlyForConfirmedGuests": {
          "type": "boolean",
          "default": false
        },
        "requestMessage": {
          "type": "string",
          "default": "Help us build the soundtrack to our night. Request a song you'd love to hear."
        },
        "playlists": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "spotifyPlaylistId": {
                "type": "string"
              },
              "trackCount": {
                "type": "number",
                "default": 0
              },
              "coverImage": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "spotifyConnection": {
          "type": "object",
          "description": "The couple's connected Spotify OAuth tokens, written by api/spotify-callback.js after a successful connect and read by api/spotify-refresh.js / api/spotify-search.js.",
          "properties": {
            "accessToken": {
              "type": "string"
            },
            "refreshToken": {
              "type": "string"
            },
            "expiresAt": {
              "type": "number"
            },
            "displayName": {
              "type": "string"
            },
            "imageUrl": {
              "type": "string"
            }
          }
        }
      }
    },
    "transport": {
      "type": "object",
      "properties": {
        "coupleNote": {
          "type": "string"
        },
        "recommendedMode": {
          "type": "string",
