      "type": "string",
      "default": "We are overjoyed to celebrate with you."
    },
    "coupleStory": {
      "type": "string"
    },
    "activeTheme": {
      "type": "string",
      "default": "still"
    },
    "activeTypography": {
      "type": "string",
      "default": "classic"
    },
    "websiteMode": {
      "type": "string",
      "enum": [
        "dark",
        "light"
      ],
      "default": "dark"
    },
    "pageTransition": {
      "type": "string",
      "enum": [
        "fade",
        "slide",
        "reveal",
        "dissolve"
      ],
      "default": "fade"
    },
    "scrollAnimation": {
      "type": "string",
      "enum": [
        "none",
        "subtle",
        "dramatic"
      ],
      "default": "subtle"
    },
    "heroEffect": {
      "type": "string",
      "enum": [
        "parallax",
        "zoomout",
        "static"
      ],
      "default": "static"
    },
    "enabledPages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "home",
        "our-story",
        "celebration",
        "rsvp"
      ]
    },
    "activeUniverse": {
      "type": "string",
      "default": "london"
    },
    "menuItems": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
