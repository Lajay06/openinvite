        "enabledModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parking": {
          "type": "object"
        },
        "publicTransport": {
          "type": "object"
        },
        "walking": {
          "type": "object"
        },
        "rideshare": {
          "type": "object"
        },
        "carHire": {
          "type": "object"
