        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "order": {
              "type": "number"
            },
            "content": {
              "type": "object"
            }
          }
        }
      }
    },
    "customPages": {
      "type": "array",
      "items": {
        "type": "object",
