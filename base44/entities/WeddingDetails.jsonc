          "items": {
            "type": "object"
          }
        }
      }
    },
    "guestSuiteTransport": {
      "type": "object",
      "description": "Guest Suite curated transport locations and tips",
      "properties": {
        "places": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "weddingPolicies": {
      "type": "object",
      "description": "Guest-facing wedding policies",
      "properties": {
        "photography": {
          "type": "object"
        },
        "socialMedia": {
          "type": "object"
        },
        "children": {
          "type": "object"
        },
        "dietary": {
          "type": "object"
        },
        "gifts": {
          "type": "object"
        },
        "dressCode": {
          "type": "object"
        },
        "lateArrival": {
          "type": "object"
        },
        "other": {
          "type": "object"
        },
        "stylingQuestionnaire": {
          "type": "object",
          "description": "Guest styling questionnaire toggle (roadmap D2) \u2014 { enabled: boolean }"
        }
      }
    },
    "emergencyContacts": {
      "type": "object",
      "description": "Wedding day emergency contacts",
      "properties": {
        "primary": {
          "type": "object"
        },
        "backup": {
          "type": "object"
        },
        "venue": {
          "type": "object"
        },
        "otherNotes": {
          "type": "string"
        }
      }
    },
    "dayVendorContacts": {
      "type": "array",
      "description": "Key vendor contacts for the wedding day",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      }
    },
    "polls": {
      "type": "array",
      "description": "Guest polls",
      "items": {
        "type": "object"
      }
    },
    "foodAndBeverage": {
      "type": "object",
      "description": "Catering details \u2014 caterer, menu, bar, cake, dietary options, etc.",
      "additionalProperties": true
    },
    "photography": {
      "type": "object",
      "description": "Photography and videography planning details \u2014 vendors, packages, shot lists, delivery timelines, etc.",
      "additionalProperties": true
    },
    "attire": {
      "type": "object",
      "description": "Wedding attire notes \u2014 bridal, groom, wedding party, etc.",
      "additionalProperties": true
    },
    "flowers": {
      "type": "object",
      "description": "Flowers and floral arrangements \u2014 florist, bouquets, ceremony and reception florals, etc.",
      "additionalProperties": true
    },
    "decorations": {
      "type": "object",
      "description": "Decorations and styling \u2014 decorator, theme, colour scheme, venue dressing, etc.",
      "additionalProperties": true
    },
    "beauty": {
      "type": "object",
      "description": "Hair and makeup planning \u2014 stylists, getting-ready people, skincare timeline, trials, etc.",
      "additionalProperties": true
    },
    "entertainmentDetails": {
      "type": "object",
      "description": "Entertainment planning \u2014 band/DJ, songs, MC, photo booth, etc.",
      "additionalProperties": true
    },
    "is_test": {
      "type": "boolean",
      "default": false,
      "description": "Set by scripts/test-persistence.mjs on every record it creates. Product queries must exclude is_test records so test-harness data can never surface in real dashboards, even if harness cleanup fails."
    }
  },
  "rls": {
    "create": null,
    "read": null,
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}