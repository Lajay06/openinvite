{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/apps/:path*", "destination": "https://base44.app/api/apps/:path*" },
    { "source": "/((?!api/)(?!\\.well-known/).*)","destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'; img-src 'self' data: blob: https://i.scdn.co https://mosaic.scdn.co https://lineup-images.scdn.co https://*.scdn.co https:" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-site" }
      ]
    },
    {
      "source": "/.well-known/apple-developer-merchantid-domain-association",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/send-onboarding-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ],
  "env": {
    "BASE44_LEGACY_SDK_IMPORTS": "true",
    "VITE_BASE44_APP_ID": "68731d183f075e406eda2236"
  },
  "build": {
    "env": {
      "BASE44_LEGACY_SDK_IMPORTS": "true",
      "VITE_BASE44_APP_ID": "68731d183f075e406eda2236"
    }
  }
}
